import requests
from bs4 import BeautifulSoup
import os
import time
import csv
from datetime import datetime

# 1. Configurações Iniciais
BASE_URL = "https://pt.wikipedia.org"
url_inicial = "https://pt.wikipedia.org/wiki/Steve_Jobs"

# O User-Agent é essencial para evitar o erro 403
headers = {
    "User-Agent": "MeuScraperAcademico/1.0 (contato@exemplo.com)"
}

os.makedirs("html_pages", exist_ok=True)

# 2. Requisição da Página Inicial
response = requests.get(url_inicial, headers=headers)
print(f"Status da Resposta Inicial: {response.status_code}")

if response.status_code == 200:
    with open("html_pages/Steve_Jobs.html", "w", encoding="utf-8") as f:
        f.write(response.text)
else:
    print("Falha ao acessar a página inicial.")
    exit()

# 3. Extração de Links Internos
soup = BeautifulSoup(response.text, "html.parser")
ignorar = ("Categoria:", "Ficheiro:", "Especial:", "Wikipedia:", "Ajuda:", "Portal:", "Predefinição:")

links_internos = []
for tag in soup.find_all("a", href=True):
    href = tag.get("href")
    # Filtra apenas links de artigos e remove âncoras (#)
    if href.startswith("/wiki/") and ":" not in href and "#" not in href:
        url_completa = BASE_URL + href
        if url_completa not in links_internos:
            links_internos.append(url_completa)

# Limitando para testes (opcional: remova [:10] para baixar todos)
links_para_baixar = links_internos[:10] 
print(f"{len(links_para_baixar)} links válidos selecionados para download.")

# 4. Download das Páginas Secundárias
paginas = {url_inicial: response.text}

for i, url in enumerate(links_para_baixar):
    try:
        resp = requests.get(url, headers=headers, timeout=10)
        if resp.status_code == 200:
            paginas[url] = resp.text
            # Limpa o nome do arquivo para evitar caracteres inválidos
            nome_arquivo = url.split("/wiki/")[-1].replace("/", "_")[:50] + ".html"
            with open(f"html_pages/{nome_arquivo}", "w", encoding="utf-8") as f:
                f.write(resp.text)
        
        time.sleep(0.5) # Respeito ao servidor
        if (i + 1) % 5 == 0:
            print(f"{i + 1} páginas processadas...")
            
    except Exception as e:
        print(f"Erro em {url}: {e}")

# 5. Processamento e Extração de Dados
dados_paginas = []
dados_imagens = []

for url, html in paginas.items():
    s = BeautifulSoup(html, "html.parser")
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")

    # Título
    tag_titulo = s.find(id="firstHeading")
    titulo = tag_titulo.get_text(strip=True) if tag_titulo else "N/A"

    # Conteúdo Principal
    conteudo = s.find(id="mw-content-text")
    
    # Primeiro Parágrafo
    primeiro_paragrafo = "N/A"
    if conteudo:
        for p in conteudo.find_all("p"):
            texto = p.get_text(strip=True)
            if len(texto) > 30:
                primeiro_paragrafo = texto
                break
    
    dados_paginas.append({
        "url": url,
        "titulo": titulo,
        "paragrafo": primeiro_paragrafo,
        "timestamp": timestamp
    })

    # Imagens
    if conteudo:
        for img in conteudo.find_all("img", src=True):
            src = img["src"]
            if src.startswith("//"):
                src = "https:" + src
            
            dados_imagens.append({
                "pagina_url": url,
                "titulo_pagina": titulo,
                "imagem_url": src,
                "timestamp": timestamp
            })

print(f"\nProcessamento concluído!")
print(f"Total de textos extraídos: {len(dados_paginas)}")
print(f"Total de imagens encontradas: {len(dados_imagens)}")
   
